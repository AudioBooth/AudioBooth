// Signing.xcconfig
// Default signing configuration for AudioBooth
//
// Maintainer: These defaults are used automatically.
// Contributors: Run scripts/setup_contributor or copy Local.xcconfig.example
//               to Local.xcconfig and update with your settings.

DEVELOPMENT_TEAM = 7MM2M9KD2W
AB_BUNDLE_ID_BASE = me.jgrenier.AudioBS
AB_APP_GROUP = group.me.jgrenier.audioBS

AB_APP_ENTITLEMENTS = AudioBooth/AudioBooth.entitlements
AB_WATCH_ENTITLEMENTS = AudioBooth Watch App/AudioBooth Watch App.entitlements
AB_WIDGET_ENTITLEMENTS = AudioBoothWidget/AudioBoothWidgetExtension.entitlements

// Pull in local overrides if they exist (the ? makes the include optional)
#include? "Local.xcconfig"
