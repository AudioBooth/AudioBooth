#!/bin/bash
#
# Sets up Local.xcconfig for contributors outside the AudioBooth team.
# This script detects available Apple Development signing identities,
# lets you pick one, and generates your Local.xcconfig.
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
LOCAL_XCCONFIG="$PROJECT_ROOT/AudioBooth/Local.xcconfig"

if [ -f "$LOCAL_XCCONFIG" ]; then
    echo "⚠️  Local.xcconfig already exists."
    read -r -p "Overwrite? [y/N] " response
    case "$response" in
        [yY]) ;;
        *) echo "Aborted."; exit 0 ;;
    esac
fi

echo "🔍 Searching for Apple Development signing identities..."
echo ""

identities=()
team_ids=()

cert=""
while IFS= read -r line; do
    if [[ "$line" == "-----BEGIN CERTIFICATE-----" ]]; then
        cert="$line"$'\n'
    elif [[ "$line" == "-----END CERTIFICATE-----" ]]; then
        cert+="$line"$'\n'
        subject=$(echo "$cert" | openssl x509 -noout -subject -nameopt RFC2253 2>/dev/null) || { cert=""; continue; }
        ou=$(echo "$subject" | sed -n 's/.*OU=\([^,]*\).*/\1/p')
        cn=$(echo "$subject" | sed -n 's/.*CN=\([^,]*\).*/\1/p')
        cert=""
        if [ -z "$ou" ] || [ -z "$cn" ]; then
            continue
        fi
        # Skip the AudioBooth team identity
        [ "$ou" = "7MM2M9KD2W" ] && continue
        identities+=("$cn")
        team_ids+=("$ou")
    elif [ -n "$cert" ]; then
        cert+="$line"$'\n'
    fi
done < <(security find-certificate -a -c "Apple Development" -p 2>/dev/null)

if [ ${#identities[@]} -eq 0 ]; then
    echo "❌ No Apple Development signing identities found."
    echo ""
    echo "Please add your Apple ID to Xcode first:"
    echo "  Xcode → Settings → Accounts → '+' → Apple ID"
    echo ""
    echo "Then re-run this script."
    exit 1
fi

echo "Found the following signing identities:"
echo ""
for i in "${!identities[@]}"; do
    echo "  $((i + 1))) ${identities[$i]}  (Team ID: ${team_ids[$i]})"
done
echo ""

if [ ${#identities[@]} -eq 1 ]; then
    selected=0
    echo "Using the only available identity."
else
    read -r -p "Select an identity [1-${#identities[@]}]: " choice
    if ! [[ "$choice" =~ ^[0-9]+$ ]]; then
        echo "❌ Invalid selection."
        exit 1
    fi
    selected=$((choice - 1))
    if [ "$selected" -lt 0 ] || [ "$selected" -ge ${#identities[@]} ]; then
        echo "❌ Invalid selection."
        exit 1
    fi
fi

team_id="${team_ids[$selected]}"
identity_name="${identities[$selected]}"

echo ""
echo "Selected: $identity_name (Team ID: $team_id)"

echo ""
read -r -p "Enter your GitHub username (for bundle identifier): " github_username

if [ -z "$github_username" ]; then
    echo "❌ GitHub username is required."
    exit 1
fi

github_username_normalized="$(echo "$github_username" | tr '[:upper:]' '[:lower:]')"
if ! [[ "$github_username_normalized" =~ ^[a-z0-9]+(-[a-z0-9]+)*$ ]]; then
    echo "❌ GitHub username may only contain letters, numbers, and hyphens, and must start with a letter or number."
    exit 1
fi
github_username="$github_username_normalized"
bundle_id="com.github.audiobooth-$github_username"

cat > "$LOCAL_XCCONFIG" << EOF
// Local.xcconfig
// Generated by scripts/setup_contributor
//
// Identity: $identity_name
// This file is gitignored and will not be committed.

DEVELOPMENT_TEAM = $team_id
AB_BUNDLE_ID_BASE = $bundle_id
AB_APP_GROUP = group.$bundle_id

AB_APP_ENTITLEMENTS = AudioBooth/AudioBooth.contributor.entitlements
AB_WATCH_ENTITLEMENTS = AudioBooth Watch App/AudioBooth Watch App.contributor.entitlements
AB_WIDGET_ENTITLEMENTS = AudioBoothWidget/AudioBoothWidgetExtension.contributor.entitlements

SWIFT_ACTIVE_COMPILATION_CONDITIONS = \$(inherited) CONTRIBUTOR_BUILD
EOF

echo ""
echo "✅ Created Local.xcconfig"
echo ""
echo "   Team ID:           $team_id"
echo "   Bundle Identifier: $bundle_id"
echo "   Entitlements:      Contributor (no iCloud, NFC, or CarPlay)"
echo ""
echo "You're ready to build! Open AudioBooth.xcodeproj and hit ▶️"
echo ""
echo "For device builds on a free account, you'll also need to remove"
echo "In-App Purchase from Signing & Capabilities in Xcode."
echo "See CONTRIBUTING.md for details."
